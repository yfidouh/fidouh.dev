---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostPreview from '../components/PostPreview.astro';
import { getPublishedPosts } from '../lib/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getPublishedPosts()).slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section>
    <h1 class="text-2xl font-semibold tracking-tight">Hey, I'm Yahya 👋</h1>
    <p class="mt-3 text-neutral-600 dark:text-neutral-400">
      I write about software and things I'm building. This site is where the
      write-ups live.
    </p>
  </section>
  <section class="mt-12">
    <div class="flex items-baseline justify-between">
      <h2 class="text-lg font-semibold">Latest posts</h2>
      <a
        href="/blog"
        class="text-sm text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100"
      >
        All posts &rarr;
      </a>
    </div>
    <div class="mt-2 divide-y divide-neutral-200 dark:divide-neutral-800">
      {posts.map((post) => <PostPreview post={post} />)}
    </div>
  </section>
</BaseLayout>
