---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
---

<BaseLayout title={`Not found — ${SITE_TITLE}`} description="Page not found.">
  <h1 class="text-2xl font-semibold tracking-tight">404</h1>
  <p class="mt-3 text-neutral-600 dark:text-neutral-400">
    That page doesn't exist. <a href="/" class="underline">Head home</a>.
  </p>
</BaseLayout>
